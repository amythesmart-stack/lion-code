{
	"version": 3,
	"pages404": true,
	"appType": "app",
	"caseSensitive": false,
	"basePath": "",
	"redirects": [
		{
			"source": "/:path+/",
			"destination": "/:path+",
			"internal": true,
			"priority": true,
			"statusCode": 308,
			"regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
		},
		{
			"source": "/:path*",
			"has": [
				{
					"type": "host",
					"value": "www.roocode.com"
				}
			],
			"destination": "https://roocode.com/:path*",
			"statusCode": 308,
			"regex": "^(?!/_next)(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
		},
		{
			"source": "/:path*",
			"has": [
				{
					"type": "header",
					"key": "x-forwarded-proto",
					"value": "http"
				}
			],
			"destination": "https://roocode.com/:path*",
			"statusCode": 308,
			"regex": "^(?!/_next)(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
		},
		{
			"source": "/cloud-waitlist",
			"destination": "https://roo-code.notion.site/238fd1401b0a8087b858e1ad431507cf?pvs=105",
			"statusCode": 307,
			"regex": "^(?!/_next)/cloud-waitlist(?:/)?$"
		},
		{
			"source": "/provider/pricing",
			"destination": "/provider",
			"statusCode": 308,
			"regex": "^(?!/_next)/provider/pricing(?:/)?$"
		}
	],
	"headers": [],
	"rewrites": {
		"beforeFiles": [],
		"afterFiles": [],
		"fallback": []
	},
	"dynamicRoutes": [
		{
			"page": "/blog/page/[page]",
			"regex": "^/blog/page/([^/]+?)(?:/)?$",
			"routeKeys": {
				"nxtPpage": "nxtPpage"
			},
			"namedRegex": "^/blog/page/(?<nxtPpage>[^/]+?)(?:/)?$"
		},
		{
			"page": "/blog/[slug]",
			"regex": "^/blog/([^/]+?)(?:/)?$",
			"routeKeys": {
				"nxtPslug": "nxtPslug"
			},
			"namedRegex": "^/blog/(?<nxtPslug>[^/]+?)(?:/)?$"
		}
	],
